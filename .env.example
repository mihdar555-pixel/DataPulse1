# Copier ce fichier en .env et remplir les valeurs

# SQLite (développement local — aucune installation requise)
DATABASE_URL=sqlite:///datapulse.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/datapulse

# MySQL (alternative)
# DATABASE_URL=mysql+mysqlclient://user:password@localhost/datapulse

SECRET_KEY=change-this-in-production
